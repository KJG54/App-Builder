{
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(node .claude/scripts/*)",
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(docker ps)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "docker ps > /dev/null 2>&1 && echo '{\"systemMessage\": \"Docker is running — Chroma available\"}' || echo '{\"systemMessage\": \"Docker is NOT running. npm run ingest will silently produce 0 docs.\"}'",
            "timeout": 5,
            "statusMessage": "Checking Docker..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/create-session-note.js",
            "timeout": 30,
            "statusMessage": "📝 Creating session note..."
          }
        ]
      }
    ]
  }
}
