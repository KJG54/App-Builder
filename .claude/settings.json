{
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(grep *)",
      "Bash(ls *)"
    ]
  },
  "hooks": {
    "PostCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/create-session-note.js",
            "timeout": 30,
            "statusMessage": "📝 Creating session note..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const input = require('fs').readFileSync(0, 'utf-8'); try { const data = JSON.parse(input); if (data.userInput && data.userInput.startsWith('/wrap-up')) { require('child_process').execSync('node .claude/scripts/wrap-up.js', {stdio: 'inherit'}); } } catch(e) { }\" || true",
            "timeout": 120,
            "statusMessage": "📋 Running wrap-up workflow..."
          }
        ]
      }
    ]
  }
}
