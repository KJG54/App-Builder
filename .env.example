# =============================================================================
# MCP SERVER CREDENTIALS
# =============================================================================
# Copy this file to .env and fill in your actual credentials
# WARNING: .env is excluded from git and should never be committed

# GitHub Personal Access Token (https://github.com/settings/tokens)
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxx

# Slack Bot Token (https://api.slack.com/apps)
SLACK_TOKEN=xoxb-xxxxxxxxxxx-xxxxxxxxxxx-xxxxxxxxxxxx

# Slack Channel Name
SLACK_CHANNEL=your-channel-name

# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================

# Project Root Directory
PROJECT_ROOT=C:\Users\kryst\Code\App Builder

# Vault Directory (for Chroma ingestion)
VAULT_PATH=Vault

# Project Prefix (used in Chroma collection names)
PROJECT_PREFIX=ai-software-factory

# =============================================================================
# CHROMA DATABASE CONFIGURATION
# =============================================================================

# Chroma Server Connection
CHROMA_SERVER_HOST=http://localhost
CHROMA_SERVER_HTTP_PORT=8000
CHROMA_SERVER_FULL_URL=http://localhost:8000

# Chroma Authentication (use 'none' for local development)
CHROMA_SERVER_AUTH_PROVIDER=none

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================

# Container Names
CHROMA_CONTAINER_NAME=app-builder-chroma

# Network Name
DOCKER_NETWORK=app-builder-network
