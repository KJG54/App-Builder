# ============================================================================
# OBSIDIAN
# ============================================================================
# Machine-specific Obsidian workspace settings
Vault/.obsidian/workspace.json
Vault/.obsidian/workspace-mobile.json
Vault/.obsidian/cache/
# Ignore all plugin files (downloaded binaries, not authored)
Vault/.obsidian/plugins/
# Ignore downloaded themes
Vault/.obsidian/themes/
# Keep Obsidian config tracked (user choices)
# - community-plugins.json (plugin list)
# - core-plugins.json (plugin toggles)
# - app.json, appearance.json, types.json (settings)
# graph.json excluded: auto-regenerated by Obsidian, noisy diffs with no signal
Vault/.obsidian/graph.json

