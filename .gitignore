# ============================================================================
# DOCKER
# ============================================================================
# Runtime volumes (NOT source code)
docker/volumes/
docker/data/
.docker/

# ============================================================================
# DATABASE & VECTOR DB
# ============================================================================
# Chroma local persistent storage (runtime data, not tracked)
.chroma/
*.db
*.sqlite
*.sqlite3

# ============================================================================
# CLAUDE CODE (LOCAL DEVELOPMENT)
# ============================================================================
# Machine-specific settings
.claude/settings.local.json

# Do NOT ignore:
# - .claude/scripts/ (tracked - production code)
# - .claude/hooks/ (tracked - automation)
# - .claude/metrics/ (tracked - observability data)
# - .claude/approvals/ (tracked - decision records)

# ============================================================================
# LOGS & TEMPORARY FILES
# ============================================================================
*.log
*.log.*
*.pot

# Temporary analysis files (development only)
_*.json
_*.py
_*.md
_*.txt

# ============================================================================
# BUILD & COMPILATION
# ============================================================================
*.o
*.so
*.dylib
*.dll
*.exe
.compiled/
out/

# ============================================================================
# RUNTIME FILES
# ============================================================================
.tmp/
*.pid
*.lock
!.gitkeep

# ============================================================================
# EXTERNAL REFERENCES (not part of this project)
