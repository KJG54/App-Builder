{
  "mcpServers": {
    "chroma": {
      "type": "stdio",
      "command": "uvx",
      "args": ["chroma-mcp@v0.2.6"],
      "env": {
        "CHROMA_CLIENT_TYPE": "http",
        "CHROMA_API_IMPL": "rest",
        "CHROMA_SERVER_HOST": "http://localhost:8000"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem"],
      "env": {
        "ALLOWED_DIRECTORIES": "${PROJECT_ROOT}"
      }
    }
  }
}
